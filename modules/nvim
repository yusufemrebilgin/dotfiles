#!/usr/bin/env bash

readonly nvim_data_dir="${XDG_DATA_HOME:-${HOME}/.local/share}/nvim"
readonly nvim_config_dir="${XDG_CONFIG_HOME:-${HOME}/.config}/nvim"
readonly nvim_config_src_dir="${DFILES_CONFIGS_DIR}/nvim"

echo "Downloading and installing Neovim AppImage..."
curl -sLO https://github.com/neovim/neovim/releases/download/v0.12.2/nvim-linux-x86_64.appimage
chmod -v u+x nvim-linux-x86_64.appimage
sudo mv -v nvim-linux-x86_64.appimage /usr/local/bin/nvim

echo "Neovim installed, applying configuration..."
rm -rf "${nvim_data_dir}" "${nvim_config_dir}"

mkdir -pv "${nvim_config_dir}" 

ln -sv "${nvim_config_src_dir}/init.lua" "${nvim_config_dir}/init.lua"
ln -sv "${nvim_config_src_dir}/lua" "${nvim_config_dir}/lua"
echo "Neovim setup and configuration completed successfully."
